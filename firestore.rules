rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny catch-all safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Shared Globals & Sanitizers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(profileId) {
      return isSignedIn() && request.auth.uid == profileId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity validator blueprints to escape update gaps and type injections
    function isValidProfile(profile) {
      return profile.keys().hasAll(['id', 'name', 'avatarUrl', 'createdAt'])
        && profile.keys().size() <= 8
        && profile.id is string && profile.id.size() <= 128
        && profile.name is string && profile.name.size() > 0 && profile.name.size() <= 100
        && profile.avatarUrl is string && profile.avatarUrl.size() <= 1048
        && profile.createdAt is string;
    }

    function isValidMedication(med) {
      return med.keys().hasAll(['id', 'profileId', 'name', 'frequency', 'times', 'durationDays', 'createdAt'])
        && med.keys().size() <= 15
        && med.id is string && med.id.size() <= 128
        && med.profileId is string && med.profileId.size() <= 128
        && med.name is string && med.name.size() > 0 && med.name.size() <= 150
        && med.frequency is string && (med.frequency == 'daily' || med.frequency == 'custom')
        && med.times is list && med.times.size() <= 10
        && med.durationDays is int && med.durationDays > 0 && med.durationDays <= 3650
        && med.createdAt is string;
    }

    function isValidDose(dose) {
      return dose.keys().hasAll(['id', 'profileId', 'medicationId', 'medicationName', 'timeOfDay', 'taken', 'date'])
        && dose.keys().size() <= 10
        && dose.id is string && dose.id.size() <= 128
        && dose.profileId is string && dose.profileId.size() <= 128
        && dose.medicationId is string && dose.medicationId.size() <= 128
        && dose.medicationName is string && dose.medicationName.size() <= 150
        && dose.timeOfDay is string && (dose.timeOfDay == 'rano' || dose.timeOfDay == 'poludnie' || dose.timeOfDay == 'wieczor')
        && dose.taken is bool
        && dose.date is string && dose.date.size() == 10;
    }

    function isValidVisit(visit) {
      return visit.keys().hasAll(['id', 'profileId', 'title', 'doctor', 'clinic', 'date', 'time'])
        && visit.keys().size() <= 9
        && visit.id is string && visit.id.size() <= 128
        && visit.profileId is string && visit.profileId.size() <= 128
        && visit.title is string && visit.title.size() > 0 && visit.title.size() <= 200
        && visit.doctor is string && visit.doctor.size() <= 150
        && visit.clinic is string && visit.clinic.size() <= 200
        && visit.date is string && visit.date.size() == 10
        && visit.time is string && visit.time.size() == 5;
    }

    function isValidNotification(notif) {
      return notif.keys().hasAll(['id', 'profileId', 'title', 'message', 'type', 'createdAt', 'read'])
        && notif.keys().size() <= 8
        && notif.id is string && notif.id.size() <= 128
        && notif.profileId is string && notif.profileId.size() <= 128
        && notif.title is string && notif.title.size() <= 200
        && notif.message is string && notif.message.size() <= 1000
        && notif.type is string && (notif.type == 'info' || notif.type == 'warning' || notif.type == 'visit' || notif.type == 'pill')
        && notif.createdAt is string
        && notif.read is bool;
    }

    // Rules for primary matching paths
    
    match /profiles/{profileId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidProfile(incoming());
      allow update: if isSignedIn() && isValidProfile(incoming()) && (incoming().id == existing().id);
      allow delete: if isSignedIn();

      // Sub-collections under a profile path
      
      match /medications/{medicationId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn() && isValidId(medicationId) && isValidMedication(incoming());
        allow update: if isSignedIn() && isValidId(medicationId) && isValidMedication(incoming()) 
          && (incoming().profileId == existing().profileId && incoming().id == existing().id);
        allow delete: if isSignedIn();
      }

      match /doses/{doseId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn() && isValidId(doseId) && isValidDose(incoming());
        allow update: if isSignedIn() && isValidId(doseId) && isValidDose(incoming())
          && (incoming().profileId == existing().profileId && incoming().id == existing().id);
        allow delete: if isSignedIn();
      }

      match /visits/{visitId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn() && isValidId(visitId) && isValidVisit(incoming());
        allow update: if isSignedIn() && isValidId(visitId) && isValidVisit(incoming())
          && (incoming().profileId == existing().profileId && incoming().id == existing().id);
        allow delete: if isSignedIn();
      }

      match /notifications/{notificationId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn() && isValidId(notificationId) && isValidNotification(incoming());
        allow update: if isSignedIn() && isValidId(notificationId) && isValidNotification(incoming())
          && (incoming().profileId == existing().profileId && incoming().id == existing().id);
        allow delete: if isSignedIn();
      }
    }
  }
}
